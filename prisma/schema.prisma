generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  firstName    String
  lastName     String
  email        String      @unique
  passwordHash String
  photo        String?
  city         String?
  country      String?
  language     String      @default("en")
  role         String      @default("user")
  createdAt    DateTime    @default(now())
  trips        Trip[]
  notes        Note[]
  checklists   Checklist[]
}

model Trip {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  name        String
  description String?
  coverPhoto  String?
  startDate   DateTime
  endDate     DateTime
  isPublic    Boolean     @default(false)
  totalBudget Float?
  status      String      @default("upcoming")
  stops       Stop[]
  notes       Note[]
  checklists  Checklist[]
  expenses    Expense[]
  createdAt   DateTime    @default(now())
}

model Stop {
  id         String     @id @default(cuid())
  tripId     String
  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  cityName   String
  country    String
  startDate  DateTime
  endDate    DateTime
  order      Int
  activities Activity[]
}

model Activity {
  id          String  @id @default(cuid())
  stopId      String
  stop        Stop    @relation(fields: [stopId], references: [id], onDelete: Cascade)
  name        String
  type        String
  cost        Float   @default(0)
  duration    Int     @default(60)
  description String?
  imageUrl    String?
  time        String?
}

model Expense {
  id          String  @id @default(cuid())
  tripId      String
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category    String
  description String
  qty         Int     @default(1)
  unitCost    Float
  amount      Float
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  stopId    String?
  content   String
  createdAt DateTime @default(now())
}

model Checklist {
  id     String          @id @default(cuid())
  userId String
  user   User            @relation(fields: [userId], references: [id])
  tripId String
  trip   Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items  ChecklistItem[]
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  label       String
  category    String    @default("misc")
  isPacked    Boolean   @default(false)
}

model City {
  id         String @id @default(cuid())
  name       String
  country    String
  region     String
  costIndex  Int    @default(3)
  popularity Int    @default(50)
  imageUrl   String?
}

model CommunityPost {
  id        String   @id @default(cuid())
  tripId    String   @unique
  userId    String
  content   String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())
}